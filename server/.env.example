# Server Configuration
PORT=5000
JWT_SECRET=your-super-secret-jwt-key-here

# Email Configuration (Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Google Calendar API Configuration (for Google Meet integration)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob
GOOGLE_REFRESH_TOKEN=your-refresh-token

# Instructions:
# 1. For Email: Enable 2-factor auth on Gmail, generate app password
# 2. For Google Meet: Create project at console.developers.google.com
# 3. Enable Google Calendar API
# 4. Create OAuth 2.0 credentials
# 5. Get refresh token using OAuth 2.0 playground